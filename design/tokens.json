{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "accent": {
      "500": { "$value": "oklch(0.82 0.20 85)", "$type": "color" },
      "300": { "$value": "oklch(from {color.accent.500} 0.82 c h)", "$type": "color" },
      "700": { "$value": "oklch(from {color.accent.500} 0.48 c h)", "$type": "color" }
    }
  },
  "font": {
    "ui":              { "$value": "Inter", "$type": "fontFamily" },
    "mono":            { "$value": "JetBrains Mono", "$type": "fontFamily" },
    "display-left":    { "$value": "Inter", "$type": "fontFamily" },
    "display-middle":  { "$value": "Bricolage Grotesque", "$type": "fontFamily" },
    "display-right":   { "$value": "Caprasimo", "$type": "fontFamily" }
  },
  "mode": {
    "left":   { "$description": "minimal editorial — apps: 30x30 landing, health" },
    "middle": { "$description": "liquid glass default — apps: midcurved.com, accountability" },
    "right":  { "$description": "neobrutalist cartoon — apps: fun apps, celebration surfaces" }
  },
  "duration": {
    "fast":   { "$value": "120ms", "$type": "duration" },
    "normal": { "$value": "220ms", "$type": "duration" }
  }
}
